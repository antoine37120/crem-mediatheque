{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "antoine37120/justwave": "^1.0",
        "astrotomic/laravel-translatable": "^11.15",
        "awcodes/palette": "^1.0",
        "cactus-galaxy/filament-astrotomic": "^0.3.0",
        "codezero/laravel-localized-routes": "^4.0",
        "eightynine/filament-excel-import": "^3.0",
        "filament/filament": "^3.2",
        "joaopaulolndev/filament-edit-profile": "^1.0",
        "laravel/framework": "^11.9",
        "laravel/scout": "^10.11",
        "laravel/tinker": "^2.9",
        "outhebox/blade-flags": "^1.5",
        "solution-forest/filament-tree": "^2.1",
        "wapmorgan/mp3info": "^0.1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laradumps/laradumps": "4.0",
        "laramint/laravel-brain": "^2.3",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.26",
        "laravel/telescope": "^5.1",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^11.0.1",
        "wire-elements/wire-spy": "^0.0.9"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "codezero/composer-preload-files": true
        }
    },
    "repositories": {
        "justwave": { 
            "type": "package",
            "package": {
                "name": "antoine37120/justwave",
                "version": "1.0",
                "source": {
                    "url": "https://github.com/antoine37120/justwave.git",
                    "type": "git",
                    "reference": "origin/master"
                },
                "autoload": {
                    "files": ["JustWave.class.php"]
                }
            }
        }

    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
